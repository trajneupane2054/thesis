      "source": [
        "X = rfm[[\"Recency\",\"Frequency\",\"Monetary\"]].copy()\n",
        "y = rfm[\"Churn\"].copy()\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.25, random_state=42, stratify=y\n",
        ")\n",
        "\n",
        "# Logistic Regression (scaled)\n",
        "logit = Pipeline([\n",
        "    (\"scaler\", StandardScaler()),\n",
        "    (\"clf\", LogisticRegression(max_iter=2000))\n",
        "])\n",
        "\n",
        "logit.fit(X_train, y_train)\n",
        "proba_logit = logit.predict_proba(X_test)[:,1]\n",
        "pred_logit = (proba_logit >= 0.5).astype(int)\n",
        "\n",
        "print(\"=== Logistic Regression ===\")\n",
        "print(\"ROC-AUC:\", roc_auc_score(y_test, proba_logit).round(3))\n",
        "print(classification_report(y_test, pred_logit))\n",
        "\n",
        "ConfusionMatrixDisplay.from_predictions(y_test, pred_logit)\n",
        "plt.title(\"Logistic Regression – Confusion Matrix\")\n",
        "plt.show()\n",
        "\n",
        "RocCurveDisplay.from_estimator(logit, X_test, y_test)\n",
        "plt.title(\"Logistic Regression – ROC\")\n",
        "plt.show()\n"
      ]
    },
