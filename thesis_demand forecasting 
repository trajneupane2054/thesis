        "# Choose the better churn model (Random Forest usually wins in Our thesis)\n",
        "best_churn_model = rf\n",
        "rfm[\"churn_proba\"] = best_churn_model.predict_proba(rfm[[\"Recency\",\"Frequency\",\"Monetary\"]])[:,1]\n",
        "last_month = (\n",
        "    df.groupby(\"Customer ID\")[\"InvoiceDate\"].max()\n",
        "      .dt.to_period(\"M\").astype(str)\n",
        "      .reset_index()\n",
        "      .rename(columns={\"Customer ID\":\"CustomerID\", \"InvoiceDate\":\"LastPurchaseMonth\"})\n",
        ")\n",
        "\n",
        "rfm2 = rfm.merge(last_month, on=\"CustomerID\", how=\"left\")\n",
        "\n",
        "monthly_churn = (\n",
        "    rfm2.groupby(\"LastPurchaseMonth\", as_index=False)\n",
        "        .agg(mean_churn_proba=(\"churn_proba\",\"mean\"),\n",
        "             customers=(\"CustomerID\",\"nunique\"))\n",
        "        .rename(columns={\"LastPurchaseMonth\":\"YearMonth\"})\n",
        ")\n",
        "\n",
        "monthly_churn[\"YearMonth\"] = pd.to_datetime(monthly_churn[\"YearMonth\"])\n",
        "monthly_churn = monthly_churn.sort_values(\"YearMonth\")\n",
        "\n",
        "display(monthly_churn.head())\n",
